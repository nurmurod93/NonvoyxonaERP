    <div class="col-md-3">
        <div class="card bg-info text-white shadow">
            <div class="card-body">
                <h5 class="card-title">📍 Tochkalar</h5>
                <a asp-controller="Tochkalar" asp-action="Index"
                   class="btn btn-light btn-sm">Ko'rish</a>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-secondary text-white shadow">
            <div class="card-body">
                <h5 class="card-title">💵 Kassa</h5>
                <a asp-controller="Kassalar" asp-action="Index"
