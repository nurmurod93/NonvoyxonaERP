@model List<NonvoyxonaERP.Application.DTOs.Xomashyo.XomashyoGetDTO>
@{
    ViewData["Title"] = "Xomashyolar";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>🌾 Xomashyolar</h2>
    <a asp-action="Create" class="btn btn-primary">➕ Yangi Xomashyo</a>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover table-striped mb-0">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Nomi</th>
                    <th>Miqdori</th>
                    <th>O'lchov</th>
                    <th>Min Daraja</th>
                    <th>Narxi</th>
                    <th>Amallar</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Id</td>
                        <td>@item.Nomi</td>
                        <td>@item.Miqdori.ToString("N2")</td>
                        <td>@item.OlchovBirligi</td>
                        <td>@item.MinDaraja.ToString("N2")</td>
                        <td>@item.Narxi.ToString("N0")</td>
                        <td>
                            <form asp-action="Delete" asp-route-id="@item.Id" method="post"
                                  onsubmit="return confirm('O\'chirishni tasdiqlaysizmi?')">
                                <button type="submit" class="btn btn-sm btn-danger">🗑️ O'chir</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
