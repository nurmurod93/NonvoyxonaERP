@model List<NonvoyxonaERP.Application.DTOs.Tochka.TochkaGetDTO>
@{
    ViewData["Title"] = "Tochkalar";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>📍 Tochkalar</h2>
    <a asp-action="Create" class="btn btn-primary">➕ Yangi Tochka</a>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover table-striped mb-0">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Nomi</th>
                    <th>Manzil</th>
                    <th>Mas'ul</th>
                    <th>Telefon</th>
                    <th>Aktiv</th>
                    <th>Amallar</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Id</td>
                        <td>@item.Nomi</td>
                        <td>@item.Manzil</td>
                        <td>@item.MasulFIO</td>
                        <td>@item.Telefon</td>
                        <td>
                            @if (item.Aktiv)
                            {
                                <span class="badge bg-success">Ha</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Yo'q</span>
                            }
                        </td>
                        <td>
                            <form asp-action="Delete" asp-route-id="@item.Id" method="post"
                                  onsubmit="return confirm('O\'chirishni tasdiqlaysizmi?')">
                                <button type="submit" class="btn btn-sm btn-danger">🗑️ O'chir</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>