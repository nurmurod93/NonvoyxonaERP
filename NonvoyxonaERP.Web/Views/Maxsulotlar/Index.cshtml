@model List<NonvoyxonaERP.Application.DTOs.Maxsulot.MaxsulotGetDTO>

@{
	ViewData["Title"] = "Maxsulotlar";
}

<div class="d-flex justify-content-between align-items-center mb-3">
	<h2>Maxsulotlar</h2>
	<a asp-action="Create", class="btn btn-primary">+ Yangi Maxsulotlar</a>
</div>

<div class="card shadow-sm">
	<div class="card-body p-0">
		<table class="table table-hover table-striped mb=0">
			<thead class="table-dark">
				<tr>
					<th>ID</th>
					<th>Nomi</th>
					<th>Kategoriya</th>
					<th>Narxi (so'm)</th>
					<th>O'lchov</th>
					<th>Aktiv</th>
					<th>Amallar</th>
				</tr>
			</thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Id</td>
                            <td>@item.Nomi</td>
                            <td>@item.Kategoryasi</td>
                            <td>@item.Narxi.ToString("N0")</td>
                            <td>@item.Olchovbirligi</td>
                            <td>
                                @if (item.Aktiv)
                                {
                                    <span class="badge bg-success">Ha</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Yo'q</span>
                                }
                            </td>
                            <td>
                                <a asp-action="Delete" asp-route-id="@item.Id"
                                   class="btn btn-sm btn-danger"
                                   onclick="return confirm('O\'chirishni tasdiqlaysizmi?')">
                                    🗑️ O'chir
                                </a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7" class="text-center text-muted py-4">
                            Ma'lumot topilmadi
                        </td>
                    </tr>
                }
            </tbody>
		</table>
	</div>
</div>
