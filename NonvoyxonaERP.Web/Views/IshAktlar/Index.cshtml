@model List<NonvoyxonaERP.Application.DTOs.IshAkt.IshAktGetDTO>
@{
    ViewData["Title"] = "Ishlab Chiqarish";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>🏭 Ishlab Chiqarish</h2>
    <a asp-action="Create" class="btn btn-primary">➕ Yangi Akt</a>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover table-striped mb-0">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Sana</th>
                    <th>Novvoy</th>
                    <th>Smena</th>
                    <th>Holat</th>
                    <th>Amallar</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Id</td>
                        <td>@item.Sana.ToString("dd.MM.yyyy")</td>
                        <td>@item.XodimFIO</td>
                        <td>@item.Smena</td>
                        <td><span class="badge bg-warning text-dark">@item.Holat</span></td>
                        <td>
                            <form asp-action="Delete" asp-route-id="@item.Id" method="post"
                                  onsubmit="return confirm('O\'chirishni tasdiqlaysizmi?')">
                                <button type="submit" class="btn btn-sm btn-danger">🗑️ O'chir</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>