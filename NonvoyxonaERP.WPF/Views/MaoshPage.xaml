<Page x:Class="NonvoyxonaERP.WPF.Views.MaoshPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F0F2F5">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal">
            <Button x:Name="btnYangi"
                    Content="➕ Maosh Hisoblash"
                    Background="#1E3A5F"
                    Foreground="White"
                    Padding="15,8"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="btnYangi_Click"/>
            <Button x:Name="btnYangilash"
                    Content="🔄 Yangilash"
                    Background="#2A5298"
                    Foreground="White"
                    Padding="15,8"
                    Margin="10,0,0,0"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="btnYangilash_Click"/>
        </StackPanel>

        <DataGrid Grid.Row="1"
                  x:Name="dgMaoshlar"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  Background="White"
                  BorderBrush="#E0E0E0"
                  BorderThickness="1"
                  RowBackground="White"
                  AlternatingRowBackground="#F8F9FA"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="#E0E0E0"
                  SelectionMode="Single"
                  CanUserResizeRows="False"
                  HeadersVisibility="Column">

            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#1E3A5F"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="Padding" Value="10,8"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>

            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="Xodim" Binding="{Binding XodimFIO}" Width="180"/>
                <DataGridTextColumn Header="Yil/Oy" Binding="{Binding Yil}" Width="60"/>
                <DataGridTextColumn Header="Oy" Binding="{Binding Oy}" Width="50"/>
                <DataGridTextColumn Header="Hisoblangan" Binding="{Binding HisoblanganMaosh, StringFormat={}{0:N0}}" Width="130"/>
                <DataGridTextColumn Header="Avans" Binding="{Binding Avans, StringFormat={}{0:N0}}" Width="100"/>
                <DataGridTextColumn Header="Shtraf" Binding="{Binding Shtraf, StringFormat={}{0:N0}}" Width="100"/>
                <DataGridTextColumn Header="Mukofot" Binding="{Binding Mukofot, StringFormat={}{0:N0}}" Width="100"/>
                <DataGridTextColumn Header="Tolangan" Binding="{Binding Tolangan, StringFormat={}{0:N0}}" Width="100"/>
                <DataGridTextColumn Header="Qoldiq" Binding="{Binding QoldiqMaosh, StringFormat={}{0:N0}}" Width="100"/>
                <DataGridTemplateColumn Header="Amallar" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="🗑️ O'chir"
                                        Background="#DC3545"
                                        Foreground="White"
                                        Padding="8,4"
                                        BorderThickness="0"
                                        Margin="2"
                                        Cursor="Hand"
                                        Click="btnOchir_Click"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
