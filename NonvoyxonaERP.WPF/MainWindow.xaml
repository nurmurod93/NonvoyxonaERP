<Window x:Class="NonvoyxonaERP.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:NonvoyxonaERP.WPF"
        mc:Ignorable="d"
        Title="NonvoyxonaERP" 
        Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#F0F2F5">
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
    

        <Border Grid.Column="0" Background="#1E3A5F">
            <StackPanel>
                <Border Background="#152B47" Padding="15" Margin="0,0,0,10">
                    <TextBlock Text="NonvoyxonaERP"
                               Foreground="White"
                               FontSize="14"
                               FontWeight="Bold"
                               TextWrapping="Wrap"/>
                </Border>

                <Button Content="📊  Dashboard" 
                            Style="{StaticResource MenuButton}"
                            Click="Dashboard_Click"/>
                <Button Content="🥖  Maxsulotlar" 
                            Style="{StaticResource MenuButton}"
                            Click="Maxsulotlar_Click"/>
                <Button Content="🌾  Xomashyolar" 
                            Style="{StaticResource MenuButton}"
                            Click="Xomashyolar_Click"/>
                <Button Content="👥  Xodimlar" 
                            Style="{StaticResource MenuButton}"
                            Click="Xodimlar_Click"/>
                <Button Content="💰  Savdo" 
                            Style="{StaticResource MenuButton}"
                            Click="Savdo_Click"/>
                <Button Content="📍  Tochkalar" 
                            Style="{StaticResource MenuButton}"
                            Click="Tochkalar_Click"/>
                <Button Content="💵  Kassa" 
                            Style="{StaticResource MenuButton}"
                            Click="Kassa_Click"/>
                <Button Content="🏭  Ishlab Chiqarish" 
                            Style="{StaticResource MenuButton}"
                            Click="IshAkt_Click"/>
                <Button Content="🚚  Transferlar" 
                            Style="{StaticResource MenuButton}"
                            Click="Transfer_Click"/>
                <Button Content="📅  Davomat" 
                          Style="{StaticResource MenuButton}"
                            Click="Davomat_Click"/>
                <Button Content="💳  Maosh" 
                            Style="{StaticResource MenuButton}"
                            Click="Maosh_Click"/>
            </StackPanel>
        </Border>
        
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="White" 
                        BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
                <TextBlock x:Name="PageTitle" 
                               Text="Dashboard" 
                               FontSize="18" 
                               FontWeight="SemiBold"
                               Foreground="#1E3A5F"
                               VerticalAlignment="Center" 
                               Margin="20,0"/>
            </Border>

            <!-- Kontent -->
            <Frame x:Name="MainFrame" 
                       Grid.Row="1" 
                       NavigationUIVisibility="Hidden"/>
        </Grid>
    </Grid>
</Window>
